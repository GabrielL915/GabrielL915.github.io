---
const { translate: t } = Astro.locals

interface Props {
  showLeft?: boolean
  leftTitle?: string
  leftUrl?: string

  showRight?: boolean
  rightTitle?: string
  rightUrl?: string

  showPageCount?: boolean
  currentPage?: number
  totalPage?: number
}

const {
  showLeft = true,
  showRight = true,
  leftTitle,
  rightTitle,
  leftUrl,
  rightUrl,
  showPageCount = true,
  currentPage,
  totalPage,
} = Astro.props
---

<footer class="pagination">
  {
    showPageCount && (
      <div class="page-count">
        {t('page_number', currentPage)} / {t('page_count', totalPage)}
      </div>
    )
  }
  <div class="flex items-center justify-between gap-4 w-full">
    {
      showLeft && (
        <a class="pagination-link not-underline-hover" title={leftTitle} href={leftUrl}>
          ← {leftTitle}
        </a>
      )
    }
    <span class="flex-1"></span>
    {
      showRight && (
        <a class="pagination-link not-underline-hover" title={rightTitle} href={rightUrl}>
          {rightTitle} →
        </a>
      )
    }
  </div>
</footer>

<style>
  .pagination {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    border-top: 1.5px solid var(--line);
    padding-top: 22px;
    margin-top: auto;
  }

  .page-count {
    font-size: 17px;
    color: var(--faint);
  }

  .pagination-link {
    color: var(--muted);
    text-decoration: none;
    font-size: 16px;
    max-width: 45%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: color 0.3s ease-in-out;
  }

  .pagination-link:hover {
    color: var(--ink);
    opacity: 1;
  }
</style>
