---
import type { Post } from '~/types'
import { formatDate } from '~/utils'
import PostCategory from './PostCategory.astro'

interface Props {
  post: Post
}

const { post } = Astro.props

const categoryList = post.data.categories ?? []
---

<header class="flex flex-col items-center text-center gap-3 pt-2 pb-6">
  <h1 class="post-heading">
    <a class="not-underline-hover" href={`/posts/${post.slug}/`}>{post.data.title}</a>
  </h1>
  <div class="post-meta-row">
    <time>{formatDate(post.data.pubDate)}</time>
    {
      categoryList.map((category) => (
        <>
          <span>·</span>
          <PostCategory category={category} />
        </>
      ))
    }
  </div>
  <svg width="180" height="12" viewBox="0 0 180 12" aria-hidden="true">
    <path
      class="brush-stroke"
      d="M3 7 C 40 3, 80 10, 120 6 S 160 5, 177 7"
      fill="none"
      stroke-width="3"
      stroke-linecap="round"
      opacity="0.85"></path>
  </svg>
</header>

<style>
  .post-heading {
    margin: 0;
    font-family: 'Yuji Syuku', serif;
    font-weight: 400;
    font-size: 42px;
    line-height: 1.25;
    color: var(--ink-strong);
    max-width: 620px;
  }

  .post-heading a {
    color: inherit;
    text-decoration: none;
  }

  .post-meta-row {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
    font-size: 16px;
    color: var(--faint);
  }
</style>
