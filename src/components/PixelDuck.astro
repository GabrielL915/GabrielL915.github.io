---
// A pixel-art duck drawn entirely with CSS box-shadow "pixels" (3px each).
// It sits on top of the vertical page label (fixed at top: 104px, right: 26px)
// and, because it lives outside the swup `main` container, it survives
// client-side page transitions without restarting its animation.
---

<div class="pixel-duck" aria-hidden="true"></div>

<style>
  .pixel-duck {
    --px: 3px;
    --y: #f2c14e; /* body */
    --s: #d99e2b; /* wing / shade */
    --o: #e07a2e; /* beak */
    --k: #2b2b2b; /* eye */
    position: fixed;
    top: 74px; /* bottom of duck (30px tall) rests at 104px, where the label starts */
    right: 12px;
    width: var(--px);
    height: var(--px);
    pointer-events: none;
    z-index: 10;
    animation: duck-bob 1.6s steps(1) infinite;
    box-shadow:
      /* head, row 0 */
      9px 0 var(--y),
      12px 0 var(--y),
      15px 0 var(--y),
      /* row 1: eye at col 3 */ 6px 3px var(--y),
      9px 3px var(--k),
      12px 3px var(--y),
      15px 3px var(--y),
      18px 3px var(--y),
      /* row 2: beak */ 0 6px var(--o),
      3px 6px var(--o),
      6px 6px var(--y),
      9px 6px var(--y),
      12px 6px var(--y),
      15px 6px var(--y),
      18px 6px var(--y),
      /* row 3 */ 6px 9px var(--y),
      9px 9px var(--y),
      12px 9px var(--y),
      15px 9px var(--y),
      18px 9px var(--y),
      /* row 4: neck into body */ 9px 12px var(--y),
      12px 12px var(--y),
      15px 12px var(--y),
      18px 12px var(--y),
      21px 12px var(--y),
      24px 12px var(--y),
      27px 12px var(--y),
      /* row 5: body + tail tip */ 9px 15px var(--y),
      12px 15px var(--y),
      15px 15px var(--y),
      18px 15px var(--y),
      21px 15px var(--y),
      24px 15px var(--y),
      27px 15px var(--y),
      30px 15px var(--y),
      33px 15px var(--y),
      36px 15px var(--s),
      /* row 6: wing */ 6px 18px var(--y),
      9px 18px var(--y),
      12px 18px var(--y),
      15px 18px var(--y),
      18px 18px var(--s),
      21px 18px var(--s),
      24px 18px var(--s),
      27px 18px var(--s),
      30px 18px var(--y),
      33px 18px var(--y),
      36px 18px var(--s),
      /* row 7: wing */ 6px 21px var(--y),
      9px 21px var(--y),
      12px 21px var(--y),
      15px 21px var(--y),
      18px 21px var(--s),
      21px 21px var(--s),
      24px 21px var(--s),
      27px 21px var(--s),
      30px 21px var(--s),
      33px 21px var(--y),
      36px 21px var(--y),
      /* row 8 */ 9px 24px var(--y),
      12px 24px var(--y),
      15px 24px var(--y),
      18px 24px var(--y),
      21px 24px var(--y),
      24px 24px var(--y),
      27px 24px var(--y),
      30px 24px var(--y),
      33px 24px var(--y),
      /* row 9: belly shadow (sitting) */ 12px 27px var(--s),
      15px 27px var(--s),
      18px 27px var(--s),
      21px 27px var(--s),
      24px 27px var(--s),
      27px 27px var(--s),
      30px 27px var(--s);
  }

  /* blink: a body-colored pixel covers the eye for a moment */
  .pixel-duck::after {
    content: '';
    position: absolute;
    left: 9px;
    top: 3px;
    width: var(--px);
    height: var(--px);
    background: var(--y);
    opacity: 0;
    animation: duck-blink 5s steps(1) infinite;
  }

  @keyframes duck-bob {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(2px);
    }
  }

  @keyframes duck-blink {
    0%,
    100% {
      opacity: 0;
    }
    92% {
      opacity: 1;
    }
    96% {
      opacity: 0;
    }
  }

  @media (max-width: 1100px) {
    .pixel-duck {
      display: none; /* the vertical label it sits on is hidden here too */
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pixel-duck,
    .pixel-duck::after {
      animation: none;
    }
  }
</style>
